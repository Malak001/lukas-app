[
  {
    "lesson_order": 1,
    "title": { "en": "Introducing Yourself: Your Name", "es": "Presentarte: Tu Nombre", "fr": "Se Présenter : Votre Nom", "de": "Sich Vorstellen: Dein Name", "ar": "التعريف بنفسك: اسمك", "zh": "自我介绍：你的名字", "pt": "Apresentando-se: Seu Nome", "ja": "自己紹介：あなたの名前" },
    "phrases": [
      {
        "target_text": "مرحبا",
        "pronunciation": "marHaban (stress on MAR)",
        "translations": { "en": "Hello", "es": "Hola", "fr": "Bonjour", "de": "Hallo", "ar": "مرحبا", "zh": "你好", "pt": "Olá", "ja": "こんにちは" }
      },
      {
        "target_text": "أهلاً",
        "pronunciation": "ahlan (casual, stress on AH)",
        "translations": { "en": "Hi", "es": "Hola (informal)", "fr": "Salut", "de": "Hi", "ar": "أهلاً", "zh": "嗨", "pt": "Oi", "ja": "やあ" }
      },
      {
        "target_text": "السلام عليكم",
        "pronunciation": "as-salaamu alaykum (formal greeting)",
        "translations": { "en": "Peace be upon you (formal hello)", "es": "La paz sea contigo (saludo formal)", "fr": "Que la paix soit sur vous (salutation formelle)", "de": "Friede sei mit dir (formelle Begrüßung)", "ar": "السلام عليكم", "zh": "愿平安与你同在（正式问候）", "pt": "Que a paz esteja contigo (saudação formal)", "ja": "あなたに平和がありますように（正式な挨拶）" }
      },
      {
        "target_text": "اسمي مريم.",
        "pronunciation": "ismi Mariam (IS-mee MAR-yam)",
        "translations": { "en": "My name is Mariam.", "es": "Me llamo Mariam.", "fr": "Je m'appelle Mariam.", "de": "Mein Name ist Mariam.", "ar": "اسمي مريم.", "zh": "我叫玛丽亚姆。", "pt": "Meu nome é Mariam.", "ja": "私の名前はマリアムです。" }
      },
      {
        "target_text": "ما اسمك؟",
        "pronunciation": "maa ismuk? (to a man) / ismuki (to a woman)",
        "translations": { "en": "What's your name?", "es": "¿Cómo te llamas?", "fr": "Comment tu t'appelles ?", "de": "Wie heißt du?", "ar": "ما اسمك؟", "zh": "你叫什么名字？", "pt": "Qual é o seu nome?", "ja": "お名前は何ですか？" }
      },
      {
        "target_text": "تشرفنا",
        "pronunciation": "tasharrafna (tah-shar-RAF-na)",
        "translations": { "en": "Nice to meet you", "es": "Mucho gusto", "fr": "Enchanté(e)", "de": "Freut mich", "ar": "تشرفنا", "zh": "很高兴认识你", "pt": "Prazer em conhecê-lo(a)", "ja": "はじめまして" }
      }
    ],
    "dialogue": [
      {
        "speaker": "A",
        "target_text": "مرحبا!",
        "pronunciation": "marHaban!",
        "translations": { "en": "Hello!", "es": "¡Hola!", "fr": "Bonjour !", "de": "Hallo!", "ar": "مرحبا!", "zh": "你好！", "pt": "Olá!", "ja": "こんにちは！" }
      },
      {
        "speaker": "B",
        "target_text": "أهلاً! ما اسمك؟",
        "pronunciation": "ahlan! maa ismuk?",
        "translations": { "en": "Hi! What's your name?", "es": "¡Hola! ¿Cómo te llamas?", "fr": "Salut ! Comment tu t'appelles ?", "de": "Hi! Wie heißt du?", "ar": "أهلاً! ما اسمك؟", "zh": "嗨！你叫什么名字？", "pt": "Oi! Qual é o seu nome?", "ja": "やあ！お名前は何ですか？" }
      },
      {
        "speaker": "A",
        "target_text": "اسمي ليلى. وأنت؟",
        "pronunciation": "ismi Layla. wa anta?",
        "translations": { "en": "My name is Layla. And you?", "es": "Me llamo Layla. ¿Y tú?", "fr": "Je m'appelle Layla. Et toi ?", "de": "Mein Name ist Layla. Und du?", "ar": "اسمي ليلى. وأنت؟", "zh": "我叫莱拉。你呢？", "pt": "Meu nome é Layla. E você?", "ja": "私の名前はライラです。あなたは？" }
      },
      {
        "speaker": "B",
        "target_text": "اسمي عمر.",
        "pronunciation": "ismi 'Omar.",
        "translations": { "en": "My name is Omar.", "es": "Me llamo Omar.", "fr": "Je m'appelle Omar.", "de": "Mein Name ist Omar.", "ar": "اسمي عمر.", "zh": "我叫奥马尔。", "pt": "Meu nome é Omar.", "ja": "私の名前はオマルです。" }
      },
      {
        "speaker": "A",
        "target_text": "تشرفنا يا عمر.",
        "pronunciation": "tasharrafna ya 'Omar.",
        "translations": { "en": "Nice to meet you, Omar.", "es": "Mucho gusto, Omar.", "fr": "Enchantée, Omar.", "de": "Freut mich, Omar.", "ar": "تشرفنا يا عمر.", "zh": "很高兴认识你，奥马尔。", "pt": "Prazer em conhecê-lo, Omar.", "ja": "オマルさん、はじめまして。" }
      },
      {
        "speaker": "B",
        "target_text": "تشرفنا أيضاً!",
        "pronunciation": "tasharrafna ayDan!",
        "translations": { "en": "Nice to meet you too!", "es": "¡Mucho gusto también!", "fr": "Enchanté aussi !", "de": "Mich auch!", "ar": "تشرفنا أيضاً!", "zh": "我也很高兴认识你！", "pt": "Prazer em conhecê-la também!", "ja": "私もはじめまして！" }
      }
    ]
  },
  {
    "lesson_order": 2,
    "title": { "en": "Where You're From", "es": "De Dónde Eres", "fr": "D'où Vous Venez", "de": "Woher Du Kommst", "ar": "من أين أنت", "zh": "你来自哪里", "pt": "De Onde Você É", "ja": "出身はどこですか" },
    "phrases": [
      {
        "target_text": "من أين أنت؟",
        "pronunciation": "min ayna anta? (to a man) / anti (to a woman)",
        "translations": { "en": "Where are you from?", "es": "¿De dónde eres?", "fr": "D'où viens-tu ?", "de": "Woher kommst du?", "ar": "من أين أنت؟", "zh": "你来自哪里？", "pt": "De onde você é?", "ja": "出身はどこですか？" }
      },
      {
        "target_text": "أنا من أمريكا",
        "pronunciation": "ana min amreeka",
        "translations": { "en": "I'm from America", "es": "Soy de Estados Unidos", "fr": "Je viens des États-Unis", "de": "Ich komme aus Amerika", "ar": "أنا من أمريكا", "zh": "我来自美国", "pt": "Eu sou dos Estados Unidos", "ja": "私はアメリカ出身です" }
      },
      {
        "target_text": "أنا أعيش في القاهرة",
        "pronunciation": "ana a'eesh fi al-qaahira",
        "translations": { "en": "I live in Cairo", "es": "Vivo en El Cairo", "fr": "J'habite au Caire", "de": "Ich lebe in Kairo", "ar": "أنا أعيش في القاهرة", "zh": "我住在开罗", "pt": "Eu moro no Cairo", "ja": "私はカイロに住んでいます" }
      },
      {
        "target_text": "ما جنسيتك؟",
        "pronunciation": "maa jinsiyyatuk? (JIN-see-yah-tuk)",
        "translations": { "en": "What's your nationality?", "es": "¿Cuál es tu nacionalidad?", "fr": "Quelle est ta nationalité ?", "de": "Welche Nationalität hast du?", "ar": "ما جنسيتك؟", "zh": "你的国籍是什么？", "pt": "Qual é a sua nacionalidade?", "ja": "国籍はどちらですか？" }
      },
      {
        "target_text": "أنا مصري",
        "pronunciation": "ana maSri (man) / maSriyya (woman)",
        "translations": { "en": "I'm Egyptian", "es": "Soy egipcio/a", "fr": "Je suis égyptien(ne)", "de": "Ich bin Ägypter/in", "ar": "أنا مصري", "zh": "我是埃及人", "pt": "Eu sou egípcio/a", "ja": "私はエジプト人です" }
      },
      {
        "target_text": "من أي مدينة أنت؟",
        "pronunciation": "min ayy madeena anta?",
        "translations": { "en": "Which city are you from?", "es": "¿De qué ciudad eres?", "fr": "De quelle ville viens-tu ?", "de": "Aus welcher Stadt kommst du?", "ar": "من أي مدينة أنت؟", "zh": "你来自哪个城市？", "pt": "De qual cidade você é?", "ja": "どちらの街の出身ですか？" }
      }
    ],
    "dialogue": [
      {
        "speaker": "A",
        "target_text": "من أين أنت؟",
        "pronunciation": "min ayna anta?",
        "translations": { "en": "Where are you from?", "es": "¿De dónde eres?", "fr": "D'où viens-tu ?", "de": "Woher kommst du?", "ar": "من أين أنت؟", "zh": "你来自哪里？", "pt": "De onde você é?", "ja": "出身はどこですか？" }
      },
      {
        "speaker": "B",
        "target_text": "أنا من فرنسا. وأنت؟",
        "pronunciation": "ana min faransa. wa anti?",
        "translations": { "en": "I'm from France. And you?", "es": "Soy de Francia. ¿Y tú?", "fr": "Je viens de France. Et toi ?", "de": "Ich komme aus Frankreich. Und du?", "ar": "أنا من فرنسا. وأنت؟", "zh": "我来自法国。你呢？", "pt": "Eu sou da França. E você?", "ja": "私はフランス出身です。あなたは？" }
      },
      {
        "speaker": "A",
        "target_text": "أنا مصرية، من القاهرة.",
        "pronunciation": "ana maSriyya, min al-qaahira.",
        "translations": { "en": "I'm Egyptian, from Cairo.", "es": "Soy egipcia, de El Cairo.", "fr": "Je suis égyptienne, du Caire.", "de": "Ich bin Ägypterin, aus Kairo.", "ar": "أنا مصرية، من القاهرة.", "zh": "我是埃及人，来自开罗。", "pt": "Eu sou egípcia, do Cairo.", "ja": "私はエジプト人で、カイロ出身です。" }
      },
      {
        "speaker": "B",
        "target_text": "رائع! وأين تعيشين الآن؟",
        "pronunciation": "raa'i'! wa ayna ta'eesheen al-aan?",
        "translations": { "en": "Nice! And where do you live now?", "es": "¡Qué bien! ¿Y dónde vives ahora?", "fr": "Super ! Et où habites-tu maintenant ?", "de": "Schön! Und wo lebst du jetzt?", "ar": "رائع! وأين تعيشين الآن؟", "zh": "太好了！你现在住在哪里？", "pt": "Legal! E onde você mora agora?", "ja": "いいですね！今はどこに住んでいますか？" }
      },
      {
        "speaker": "A",
        "target_text": "أعيش في دبي.",
        "pronunciation": "a'eesh fi dubay.",
        "translations": { "en": "I live in Dubai.", "es": "Vivo en Dubái.", "fr": "J'habite à Dubaï.", "de": "Ich lebe in Dubai.", "ar": "أعيش في دبي.", "zh": "我住在迪拜。", "pt": "Eu moro em Dubai.", "ja": "私はドバイに住んでいます。" }
      },
      {
        "speaker": "B",
        "target_text": "مدينة جميلة!",
        "pronunciation": "madeena jameela!",
        "translations": { "en": "Beautiful city!", "es": "¡Una ciudad hermosa!", "fr": "Une belle ville !", "de": "Eine schöne Stadt!", "ar": "مدينة جميلة!", "zh": "很美的城市！", "pt": "Uma cidade linda!", "ja": "美しい街ですね！" }
      }
    ]
  },
  {
    "lesson_order": 3,
    "title": { "en": "Greetings", "es": "Saludos", "fr": "Salutations", "de": "Begrüßungen", "ar": "التحيات", "zh": "问候语", "pt": "Cumprimentos", "ja": "挨拶" },
    "phrases": [
      {
        "target_text": "صباح الخير",
        "pronunciation": "SabaaH al-khayr",
        "translations": { "en": "Good morning", "es": "Buenos días", "fr": "Bonjour (matin)", "de": "Guten Morgen", "ar": "صباح الخير", "zh": "早上好", "pt": "Bom dia", "ja": "おはようございます" }
      },
      {
        "target_text": "مساء الخير",
        "pronunciation": "masaa' al-khayr",
        "translations": { "en": "Good afternoon/evening", "es": "Buenas tardes", "fr": "Bonsoir", "de": "Guten Tag/Abend", "ar": "مساء الخير", "zh": "下午好/晚上好", "pt": "Boa tarde/noite", "ja": "こんばんは" }
      },
      {
        "target_text": "تصبح على خير",
        "pronunciation": "tuSbiH 'ala khayr (to a man) / tuSbiHi (to a woman)",
        "translations": { "en": "Good night", "es": "Buenas noches", "fr": "Bonne nuit", "de": "Gute Nacht", "ar": "تصبح على خير", "zh": "晚安", "pt": "Boa noite (ao dormir)", "ja": "おやすみなさい" }
      },
      {
        "target_text": "هاي",
        "pronunciation": "haay (casual)",
        "translations": { "en": "Hi (casual)", "es": "Hola (casual)", "fr": "Salut (décontracté)", "de": "Hi (locker)", "ar": "هاي", "zh": "嗨（随意）", "pt": "Oi (casual)", "ja": "やあ（カジュアル）" }
      },
      {
        "target_text": "كيف حالك؟",
        "pronunciation": "kayf Haaluk? (to a man) / Haaluki (to a woman)",
        "translations": { "en": "How are you?", "es": "¿Cómo estás?", "fr": "Comment vas-tu ?", "de": "Wie geht es dir?", "ar": "كيف حالك؟", "zh": "你好吗？", "pt": "Como você está?", "ja": "お元気ですか？" }
      },
      {
        "target_text": "بخير، الحمد لله",
        "pronunciation": "bikhayr, al-Hamdu lillah",
        "translations": { "en": "I'm fine, thank God", "es": "Estoy bien, gracias a Dios", "fr": "Je vais bien, Dieu merci", "de": "Mir geht's gut, Gott sei Dank", "ar": "بخير، الحمد لله", "zh": "我很好，感谢主", "pt": "Estou bem, graças a Deus", "ja": "元気です、おかげさまで" }
      }
    ],
    "dialogue": [
      {
        "speaker": "A",
        "target_text": "صباح الخير!",
        "pronunciation": "SabaaH al-khayr!",
        "translations": { "en": "Good morning!", "es": "¡Buenos días!", "fr": "Bonjour !", "de": "Guten Morgen!", "ar": "صباح الخير!", "zh": "早上好！", "pt": "Bom dia!", "ja": "おはようございます！" }
      },
      {
        "speaker": "B",
        "target_text": "صباح النور! كيف حالك؟",
        "pronunciation": "SabaaH an-noor! kayf Haaluk?",
        "translations": { "en": "Good morning (reply)! How are you?", "es": "¡Buenos días (respuesta)! ¿Cómo estás?", "fr": "Bonjour (réponse) ! Comment vas-tu ?", "de": "Guten Morgen (Antwort)! Wie geht's dir?", "ar": "صباح النور! كيف حالك؟", "zh": "早上好（回应）！你好吗？", "pt": "Bom dia (resposta)! Como você está?", "ja": "おはようございます（返事）！お元気ですか？" }
      },
      {
        "speaker": "A",
        "target_text": "بخير، الحمد لله. وأنت؟",
        "pronunciation": "bikhayr, al-Hamdu lillah. wa anta?",
        "translations": { "en": "I'm fine, thank God. And you?", "es": "Estoy bien, gracias a Dios. ¿Y tú?", "fr": "Je vais bien, Dieu merci. Et toi ?", "de": "Mir geht's gut, Gott sei Dank. Und dir?", "ar": "بخير، الحمد لله. وأنت؟", "zh": "我很好，感谢主。你呢？", "pt": "Estou bem, graças a Deus. E você?", "ja": "元気です、おかげさまで。あなたは？" }
      },
      {
        "speaker": "B",
        "target_text": "بخير أيضاً، شكراً.",
        "pronunciation": "bikhayr ayDan, shukran.",
        "translations": { "en": "I'm fine too, thanks.", "es": "Yo también estoy bien, gracias.", "fr": "Je vais bien aussi, merci.", "de": "Mir geht's auch gut, danke.", "ar": "بخير أيضاً، شكراً.", "zh": "我也很好，谢谢。", "pt": "Também estou bem, obrigado.", "ja": "私も元気です、ありがとう。" }
      },
      {
        "speaker": "A",
        "target_text": "أراك لاحقاً!",
        "pronunciation": "araaka laaHiqan!",
        "translations": { "en": "See you later!", "es": "¡Nos vemos luego!", "fr": "À plus tard !", "de": "Bis später!", "ar": "أراك لاحقاً!", "zh": "回头见！", "pt": "Até mais tarde!", "ja": "また後で！" }
      },
      {
        "speaker": "B",
        "target_text": "تصبح على خير!",
        "pronunciation": "tuSbiH 'ala khayr!",
        "translations": { "en": "Good night!", "es": "¡Buenas noches!", "fr": "Bonne nuit !", "de": "Gute Nacht!", "ar": "تصبح على خير!", "zh": "晚安！", "pt": "Boa noite!", "ja": "おやすみなさい！" }
      }
    ]
  },
  {
    "lesson_order": 4,
    "title": { "en": "Politeness & Manners", "es": "Cortesía y Modales", "fr": "Politesse et Bonnes Manières", "de": "Höflichkeit und Umgangsformen", "ar": "الأدب والمجاملات", "zh": "礼貌用语", "pt": "Educação e Boas Maneiras", "ja": "礼儀とマナー" },
    "phrases": [
      {
        "target_text": "من فضلك",
        "pronunciation": "min faDlik (to a woman) / faDlak (to a man)",
        "translations": { "en": "Please", "es": "Por favor", "fr": "S'il te plaît", "de": "Bitte", "ar": "من فضلك", "zh": "请", "pt": "Por favor", "ja": "お願いします" }
      },
      {
        "target_text": "شكراً",
        "pronunciation": "shukran (SHUK-ran)",
        "translations": { "en": "Thank you", "es": "Gracias", "fr": "Merci", "de": "Danke", "ar": "شكراً", "zh": "谢谢", "pt": "Obrigado/a", "ja": "ありがとう" }
      },
      {
        "target_text": "عفواً",
        "pronunciation": "'afwan ('AF-wan)",
        "translations": { "en": "You're welcome", "es": "De nada", "fr": "Je t'en prie", "de": "Bitte schön (Antwort)", "ar": "عفواً", "zh": "不客气", "pt": "De nada", "ja": "どういたしまして" }
      },
      {
        "target_text": "لو سمحت",
        "pronunciation": "law samaHt (excuse me, to get attention)",
        "translations": { "en": "Excuse me", "es": "Disculpa", "fr": "Excusez-moi", "de": "Entschuldigung", "ar": "لو سمحت", "zh": "打扰一下", "pt": "Com licença", "ja": "すみません" }
      },
      {
        "target_text": "آسف",
        "pronunciation": "aasif (man) / aasifa (woman)",
        "translations": { "en": "Sorry", "es": "Lo siento", "fr": "Désolé(e)", "de": "Entschuldigung / Es tut mir leid", "ar": "آسف", "zh": "对不起", "pt": "Desculpe", "ja": "ごめんなさい" }
      },
      {
        "target_text": "لا مشكلة",
        "pronunciation": "laa mushkila",
        "translations": { "en": "No problem", "es": "No hay problema", "fr": "Pas de problème", "de": "Kein Problem", "ar": "لا مشكلة", "zh": "没问题", "pt": "Sem problema", "ja": "問題ありません" }
      }
    ],
    "dialogue": [
      {
        "speaker": "A",
        "target_text": "لو سمحت، أين الحمام؟",
        "pronunciation": "law samaHt, ayna al-Hammaam?",
        "translations": { "en": "Excuse me, where's the bathroom?", "es": "Disculpa, ¿dónde está el baño?", "fr": "Excusez-moi, où sont les toilettes ?", "de": "Entschuldigung, wo ist die Toilette?", "ar": "لو سمحت، أين الحمام؟", "zh": "打扰一下，洗手间在哪里？", "pt": "Com licença, onde é o banheiro?", "ja": "すみません、お手洗いはどこですか？" }
      },
      {
        "speaker": "B",
        "target_text": "هناك، من فضلك.",
        "pronunciation": "hunaak, min faDlik.",
        "translations": { "en": "Over there, please.", "es": "Allí, por favor.", "fr": "Là-bas, s'il te plaît.", "de": "Dort drüben, bitte.", "ar": "هناك، من فضلك.", "zh": "那边，请。", "pt": "Ali, por favor.", "ja": "あちらです、どうぞ。" }
      },
      {
        "speaker": "A",
        "target_text": "شكراً جزيلاً!",
        "pronunciation": "shukran jazeelan!",
        "translations": { "en": "Thank you very much!", "es": "¡Muchas gracias!", "fr": "Merci beaucoup !", "de": "Vielen Dank!", "ar": "شكراً جزيلاً!", "zh": "非常感谢！", "pt": "Muito obrigado(a)!", "ja": "どうもありがとう！" }
      },
      {
        "speaker": "B",
        "target_text": "عفواً.",
        "pronunciation": "'afwan.",
        "translations": { "en": "You're welcome.", "es": "De nada.", "fr": "Je t'en prie.", "de": "Bitte schön.", "ar": "عفواً.", "zh": "不客气。", "pt": "De nada.", "ja": "どういたしまして。" }
      },
      {
        "speaker": "A",
        "target_text": "آسف، هل أزعجتك؟",
        "pronunciation": "aasif, hal az'ajtuk?",
        "translations": { "en": "Sorry, did I bother you?", "es": "Perdón, ¿te molesté?", "fr": "Désolé, je t'ai dérangé ?", "de": "Entschuldigung, habe ich dich gestört?", "ar": "آسف، هل أزعجتك؟", "zh": "抱歉，我打扰你了吗？", "pt": "Desculpe, eu te incomodei?", "ja": "ごめんなさい、迷惑でしたか？" }
      },
      {
        "speaker": "B",
